        <div class="xlink-col">
          <h3>Services</h3>
          <ul>
            <% services.forEach(function(s){ %>
              <li><a href="/services/<%= s.slug %>"><%= s.shortName || s.name %></a></li>
            <% }) %>
          </ul>
        </div>
        <div class="xlink-col">
          <h3>Areas we serve</h3>
          <ul>
            <% areas.forEach(function(a){ %>
              <li><a href="/areas/<%= a.slug %>"><%= a.shortName || a.name %></a></li>
            <% }) %>
          </ul>
        </div>
        <div class="xlink-col">
          <h3>More</h3>
          <ul>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/#projects">Recent projects</a></li>
            <li><a href="/#process">Our process</a></li>
            <li><a href="/#contact">Get an estimate</a></li>
          </ul>
        </div>
        <div class="xlink-col">
          <h3>Contact</h3>
          <p><strong>Gravity Construction</strong><br/>
          Santa Cruz, CA<br/>
          CSLB #1075110</p>
          <p><a class="nav-cta" href="tel:+18312344669">(831) 234-4669</a></p>
          <p><a href="mailto:dhollinga6@gmail.com">dhollinga6@gmail.com</a></p>
        </div>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <img src="/gravity.png" alt="Gravity Construction" class="footer-logo" width="120" height="120" />
        <p>Locally owned. Licensed. Insured.</p>
        <p class="footer-license">CSLB #1075110</p>
      </div>
      <p class="footer-copy">&copy; <%= new Date().getFullYear() %> Gravity Construction. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Lightweight nav toggle for deep pages (matches homepage behavior)
    (function(){
      var btn = document.querySelector('.nav-toggle');
      var nav = document.getElementById('primary-nav');
      if (!btn || !nav) return;
      btn.addEventListener('click', function(){
        var open = nav.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    })();
  </script>
</body>
</html>
