<%- include('../partials/head', { title }) %>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { user, currentPath }) %>
  <main class="content">
    <%- include('../partials/flash', { flash: typeof flash !== 'undefined' ? flash : null }) %>

    <div class="page-head">
      <h1>Instagram posts</h1>
      <a class="btn btn-primary" href="/admin/instagram/new">+ Add post</a>
    </div>

    <p class="muted">Posts shown here render on the homepage as official Instagram embeds. Lower sort order = shown first.</p>

    <div class="card" style="padding: 0; overflow: hidden;">
      <table>
        <thead>
          <tr>
            <th>URL</th>
            <th>Caption</th>
            <th>Sort</th>
            <th>Status</th>
            <th style="width: 180px;"></th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows.length) { %>
            <tr><td colspan="5" class="muted" style="padding: 2rem; text-align: center;">No posts yet. Paste your first one.</td></tr>
          <% } %>
          <% rows.forEach(function(r) { %>
            <tr>
              <td><a href="<%= r.url %>" target="_blank" rel="noopener" style="font-size:.85rem;"><%= r.url %></a></td>
              <td class="muted" style="font-size:.9rem; max-width: 320px;"><%= r.caption || '—' %></td>
              <td><%= r.sort_order %></td>
              <td>
                <% if (r.published) { %><span class="pill pill-on">Live</span><% } else { %><span class="pill pill-off">Hidden</span><% } %>
              </td>
              <td style="text-align: right;">
                <a class="btn btn-ghost" href="/admin/instagram/<%= r.id %>/edit">Edit</a>
                <form method="POST" action="/admin/instagram/<%= r.id %>/delete" style="display:inline" onsubmit="return confirm('Remove this post?');">
                  <button type="submit" class="btn btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>
</body>
</html>
