<%- include('../partials/head', { title }) %>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { user, currentPath }) %>
  <main class="content">
    <%- include('../partials/flash', { flash: typeof flash !== 'undefined' ? flash : null }) %>

    <div class="page-head">
      <h1><%= row ? 'Edit testimonial' : 'New testimonial' %></h1>
      <a class="btn btn-ghost" href="/admin/testimonials">← Back</a>
    </div>

    <form method="POST" action="<%= action %>" class="card">
      <label>
        <span>Quote</span>
        <textarea name="quote" rows="4" required><%= row ? row.quote : '' %></textarea>
      </label>

      <div class="grid grid-2">
        <label>
          <span>Author</span>
          <input type="text" name="author" required value="<%= row ? row.author : '' %>" placeholder="Jane D." />
        </label>
        <label>
          <span>Location (optional)</span>
          <input type="text" name="location" value="<%= row && row.location ? row.location : '' %>" placeholder="Capitola" />
        </label>
      </div>

      <div class="grid grid-2">
        <label>
          <span>Rating (1–5, optional)</span>
          <select name="rating">
            <option value="">— none —</option>
            <% [1,2,3,4,5].forEach(function(n) { %>
              <option value="<%= n %>" <%= row && row.rating === n ? 'selected' : '' %>><%= '★'.repeat(n) %></option>
            <% }) %>
          </select>
        </label>
        <label>
          <span>Attach to project (optional)</span>
          <select name="project_id">
            <option value="">— none —</option>
            <% projects.forEach(function(p) { %>
              <option value="<%= p.id %>" <%= row && row.project_id === p.id ? 'selected' : '' %>><%= p.title %></option>
            <% }) %>
          </select>
        </label>
      </div>

      <div class="grid grid-2">
        <label>
          <span>Sort order</span>
          <input type="number" name="sort_order" value="<%= row ? row.sort_order : 0 %>" />
        </label>
        <label style="display:flex; align-items:center; gap:.5rem; padding-top:1.4rem;">
          <input type="checkbox" name="published" <%= (!row || row.published) ? 'checked' : '' %> style="width:auto;" />
          <span style="margin:0; text-transform:none; letter-spacing:0; font-size:.95rem;">Published (show on site)</span>
        </label>
      </div>

      <div class="action-row">
        <a class="btn btn-ghost" href="/admin/testimonials">Cancel</a>
        <button type="submit" class="btn btn-primary"><%= row ? 'Save changes' : 'Create testimonial' %></button>
      </div>
    </form>
  </main>
</div>
</body>
</html>
