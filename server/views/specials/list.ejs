<%- include('../partials/head', { title }) %>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { user, currentPath }) %>
  <main class="content">
    <%- include('../partials/flash', { flash: typeof flash !== 'undefined' ? flash : null }) %>

    <div class="page-head">
      <h1>Specials</h1>
      <a class="btn btn-primary" href="/admin/specials/new">+ New special</a>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Window</th>
            <th>Status</th>
            <th>Sort</th>
            <th style="width: 180px;"></th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows.length) { %>
            <tr><td colspan="5" class="muted" style="padding: 2rem; text-align: center;">No specials yet. Create the first one.</td></tr>
          <% } %>
          <% rows.forEach(function(r) { %>
            <tr>
              <td>
                <strong><%= r.title %></strong>
                <% if (r.cta_label) { %><br/><span class="muted" style="font-size:.85rem"><%= r.cta_label %> → <%= r.cta_href %></span><% } %>
              </td>
              <td class="muted" style="font-size:.85rem">
                <%= r.starts_at || '—' %><br/><%= r.ends_at || 'no end' %>
              </td>
              <td>
                <% if (r.active) { %><span class="pill pill-on">Active</span><% } else { %><span class="pill pill-off">Off</span><% } %>
              </td>
              <td><%= r.sort_order %></td>
              <td style="text-align: right;">
                <a class="btn btn-ghost" href="/admin/specials/<%= r.id %>/edit">Edit</a>
                <form method="POST" action="/admin/specials/<%= r.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this special?');">
                  <button type="submit" class="btn btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>
</body>
</html>
