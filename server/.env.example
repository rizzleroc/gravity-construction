# Copy to .env and fill in. Never commit .env to git.

# Port the Node server listens on (behind Nginx on the VPS)
PORT=5435

# Long random string — used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# OpenWeatherMap API key for the Santa Cruz weather widget.
# Sign up free at https://openweathermap.org/api — "Current Weather Data" tier is free.
# Leave blank to fall back to weather.gov (no key required, US-only, less rich data).
OPENWEATHER_API_KEY=

# Santa Cruz, CA coordinates (pre-filled — change if you want a different city)
WEATHER_LAT=36.9741
WEATHER_LON=-122.0308

# Set to "production" on the VPS. In production, cookies are marked secure (HTTPS only).
NODE_ENV=development

# Public base URL — used in the sitemap, canonical tags, OG tags, and deep-page
# JSON-LD. Must match the live domain exactly (https, no trailing slash).
BASE_URL=https://gravityconstructionsc.com

# ---------- Analytics + Search Console (optional) ----------
# Leave blank in development so local browsing doesn't pollute production analytics.
# Both are safely no-op when blank.

# Google Analytics 4 Measurement ID from analytics.google.com → property settings.
# Looks like: G-XXXXXXXXXX
GA4_MEASUREMENT_ID=

# Google Search Console verification token (the `content` value from the HTML-tag
# verification method at search.google.com/search-console).
GSC_VERIFICATION=

# ---------- Twilio 2FA for admin login (optional) ----------
# When all three are set AND the admin user has a phone on file (see
# `npm run set-phone -- <email> +1XXXXXXXXXX`), admin login requires an
# SMS code after the password step. Leave blank to disable 2FA.
#
# Values come from https://console.twilio.com/ :
#   - Account SID + Auth Token are on the main dashboard
#   - Create a Verify Service at Verify → Services → Create new
#     (the SID starts with VA… — that's the "Messaging Service SID" below,
#     even though it's technically the Verify Service SID)
#
# In production these should live in a gitignored `.env.local` at the
# project ROOT (one level above `server/`). server.js auto-loads that file.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
